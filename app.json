{
  "name": "subzero-md",
  "description": "A high-performance, multi-device WhatsApp automation bot built on Node.js, engineered for reliability, scalability, and advanced message handling. Developed by 乙𝐎𝐔𝐕𝐈𝐊, this bot supports session-based authentication, dynamic command execution, and optional database integrations for persistent data storage.",
  "logo": "https://mrfrankk-cdn.hf.space/mrfrank/subzero.png",
  "keywords": ["SUBZERO-MD", "whatsapp-bot", "automation", "multi-device", "nodejs"],
  "success_url": "/",  
  "repository": "https://github.com/mrfrankofcc/SUBZERO-MD",
  "stack": "heroku-24",

  "env": {
    "SESSION_ID": {
      "description": "Secure authentication session string used to connect the bot to WhatsApp Web.",
      "required": true,
      "value": "Ice~agMzue"
    },

    "OWNER_NUMBER": {
      "description": "Primary administrator WhatsApp number in international format.",
      "required": true,
      "value": "918918860814"
    },

    "DATABASE_URL": {
      "description": "Database connection URI for persistent storage.",
      "required": false,
      "value": ""
    },

    "BOT_NAME": {
      "description": "Display name of the bot.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "BOT_OWNER": {
      "description": "Display name of the bot owner.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "PREFIXES": {
      "description": "Command trigger prefixes.",
      "required": false,
      "value": "."
    },

    "PACKNAME": {
      "description": "Default sticker pack name.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "COMMAND_MODE": {
      "description": "Operational mode: public or private.",
      "required": false,
      "value": "public"
    },

    "TIMEZONE": {
      "description": "System timezone.",
      "required": false,
      "value": "Asia/Kolkata"
    },

    "REMOVEBG_KEY": {
      "description": "API key from remove.bg service.",
      "required": false,
      "value": ""
    }
  },

  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" },
    { "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git" }
  ],

  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
