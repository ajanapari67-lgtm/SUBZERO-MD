    "OWNER_NUMBER": {
      "description": "Primary administrator WhatsApp number.",
      "required": true,
      "value": "918918860814"
    },

    "DATABASE_URL": {
      "description": "MongoDB connection URI or other DB strings.",
      "required": false,
      "value": ""
    },

    "BOT_NAME": {
      "description": "Display name of the bot.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "BOT_OWNER": {
      "description": "Display name of the bot owner.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "PREFIXES": {
      "description": "Command trigger prefixes.",
      "required": false,
      "value": "."
    },

    "PACKNAME": {
      "description": "Default sticker pack name.",
      "required": false,
      "value": "乙𝐎𝐔𝐕𝐈𝐊"
    },

    "COMMAND_MODE": {
